[Unit]
Description=vLLM Qwen3-14B Server
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=root
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vllm-qwen3
WorkingDirectory=/your-path
Environment="PATH=/your-path/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="CUDA_VISIBLE_DEVICES=0"
Environment="VLLM_ALLOW_LONG_MAX_MODEL_LEN=1"
ExecStart=/your-path/bin/python -m vllm.entrypoints.openai.api_server \
    --model Qwen/Qwen3-14B-AWQ \
    --host 0.0.0.0 \
    --port 8002 \
    --gpu-memory-utilization 0.94 \
    --max-model-len 60000 \
    --max-num-seqs 1 \
    --enforce-eager \
    --dtype auto \
    --max-num-batched-tokens 2048 \
    --enable-prefix-caching \
    --enable-chunked-prefill \
    --quantization awq_marlin \
    --served-model-name qwen3-14b \
    --api-key "your-secret-api-key" \
    --enable-auto-tool-choice \
    --tool-call-parser hermes \
    --hf-overrides '{"rope_scaling": {"rope_type": "yarn", "factor": 4.0, "original_max_position_embeddings": 32768}}' \
    --chat-template-content-format string

[Install]
WantedBy=multi-user.target
